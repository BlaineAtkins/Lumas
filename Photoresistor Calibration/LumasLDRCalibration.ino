}


float getLux(int rawADC) {
  // Convert ADC to Voltage (assuming ESP32 12-bit ADC on 3.3V)
  float voltage = rawADC * (3.3 / 4095.0);
  
  // Calculate LDR Resistance (assuming LDR is connected to 3.3V and R_FIXED to GND)
  if (voltage <= 0.05) return 0; // Prevent division by zero/noise
  float resistance = R_FIXED * (3.3 - voltage) / voltage;

  // Formula: Lux = ( (RL_10 * 10^gamma) / Resistance ) ^ (1/gamma)
  float lux = pow((RL_10 * pow(10, GAMMA) / resistance), (1.0 / GAMMA));
  return lux;
}


float getLightFromLED(int color, int brightness) {
    // Ensure color and brightness are within valid bounds
    color = constrain(color, 0, 1023);
    brightness = constrain(brightness, 0, 255);

    if (brightness == 0) return 0.0;

    float x0, x1, y0, y1;
    
    // Determine which "bin" the current brightness falls into
    if (brightness <= 16) {
        x0 = 0;   y0 = 0;
        x1 = 16;  y1 = led_lookup31[color][0];
    } 
    else if (brightness <= 60) {
        x0 = 16;  y0 = led_lookup31[color][0];
        x1 = 60;  y1 = led_lookup31[color][1];
    } 
    else if (brightness <= 122) {
        x0 = 60;  y0 = led_lookup31[color][1];
        x1 = 122; y1 = led_lookup31[color][2];
    } 
    else {
        x0 = 122; y0 = led_lookup31[color][2];
        x1 = 255; y1 = led_lookup31[color][3];
    }

    // Standard Linear Interpolation Formula: y = y0 + (x - x0) * ((y1 - y0) / (x1 - x0))
    float interpolatedADC = y0 + (float)(brightness - x0) * ((y1 - y0) / (x1 - x0));
    
    return interpolatedADC;
}





int getColor(int color,char component){
  int r;
  int g;
  int b;

  if(color==0){
    r=255;
    g=0;
    b=0;
  }else if(color<170){
    r=255;
    b=0;
    g=(color/170.0)*255;
  }else if(color<170*2){
    color=color-170;
    b=0;
    g=255;
    r=((170-color)/170.0)*255;
  }else if(color<170*3){
    color=color-170*2;
    r=0;
    g=255;
    b=(color/170.0)*255;
  }else if(color<170*4){
    color=color-170*3;
    r=0;
    b=255;
    g=((170-color)/170.0)*255;
  }else if(color<170*5){
    color=color-170*4;
    g=0;
    b=255;
    r=(color/170.0)*255;
  }else if(color<1025){
    color=color-170*5;
    g=0;
    r=255;
    b=((173-color)/173.0)*255; //173 cause this loop absorbs the remainder of 1024/6
  }else{ //should never be called, but if someone calls for a number outside of the range, we should return black instead of some strange number
    r=0;
    g=0;
    b=0;
  }
  if(component=='r'){
    return r;
  }else if(component=='g'){
    return g;
  }else if(component=='b'){
    return b;
  }else{
    return 0; //return 0 if they call for a component other than r/g/b
  }
}



