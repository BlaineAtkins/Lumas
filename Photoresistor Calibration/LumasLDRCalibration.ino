//Rotary Encoder setup
#define ENCODER_PIN_IN1 18
#define ENCODER_PIN_IN2 19
RotaryEncoder *encoder = nullptr; //A pointer to the dynamic created rotary encoder instance. This will be done in setup()
IRAM_ATTR void checkEncoderPosition() //ISR called on any change of one of the input signals
{
  encoder->tick(); // just call tick() to check the state.
}


void Received_Message(char* topic, byte* payload, unsigned int length) {
  Serial.print("Message arrived [");
  Serial.print(topic);
  Serial.print("] ");
  for (int i = 0; i < length; i++) {
    Serial.print((char)payload[i]);
  }
  Serial.println();

  char payloadCStr[length+1]; 
  memcpy(payloadCStr, payload, length);
  payloadCStr[length] = '\0'; // Add a null terminator so from here forward we can treat the payload like a cstring and use strcpy etc

  float calibrationVal=atof(payloadCStr);

  //set value in memory so it reacts immediately
  mqttCalibrationVal=calibrationVal;

  EEPROM.begin(173);
  EEPROM.write(56, 'C');  //set this byte so the ESP32 knows to look for a calibration value in eeprom
  EEPROM.put(57, calibrationVal);
  EEPROM.commit();
  EEPROM.end();

}


void setup() {
  lights.begin();
  lights.clear();

  encoder = new RotaryEncoder(ENCODER_PIN_IN1, ENCODER_PIN_IN2, RotaryEncoder::LatchMode::TWO03);
  attachInterrupt(digitalPinToInterrupt(ENCODER_PIN_IN1), checkEncoderPosition, CHANGE);
  attachInterrupt(digitalPinToInterrupt(ENCODER_PIN_IN2), checkEncoderPosition, CHANGE);

  Serial.begin(115200);

  WiFi.begin("Blaine-Laptop-Hotspot","12345678");
  client.setServer("lumas.live", 1883);
  client.setCallback(Received_Message);

}

void reconnect(){
  int disconnectBeganAt=millis();
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    if (client.connect("BlaineLumasTest")) { //name of this client
      Serial.println("connected");
      client.subscribe("LumasLDRCalibration/set");
      client.publish("LumasLDRCalibration/readings","Set calibration val in memory & EEPROM by sending a float to LumasLDRCalibration/set.\nLumas will start at color 904, at which the reference raw totalLux is 10.1 in a completely dark room.");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      // Wait 5 seconds before retrying
      delay(5000);
    }
}
}


